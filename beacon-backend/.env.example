# ─── DATABASE ───────────────────────────────────────────
# Password having @ — must be URL-encoded as %40
DATABASE_URL=postgresql://beacon_user:Passwordhere@localhost:5432/beacon

# ─── REDIS ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ─── EMAIL ENCRYPTION ───────────────────────
# Generate your key once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

EMAIL_ENCRYPTION_KEY=your-fernet-key-here

# ─── ENVIRONMENT ────────────────────────────────────────
# Set to "production" on your live server.
# In production, the app will refuse to start if EMAIL_ENCRYPTION_KEY is missing.
ENVIRONMENT=development

# ─── EMAIL (SMTP) — optional for dev; OTP prints in terminal if this fails ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=youremail@gmail.com
FROM_NAME=Beacon

# ─── APP ─────────────────────────────────────────────────
APP_NAME=Beacon
FRONTEND_URL=http://localhost:5173
OTP_EXPIRE_MINUTES=10